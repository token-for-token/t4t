{
  "name": "t4t-container",
  "version": "0.1.0",
  "description": "Token4Token client/provider container — OpenAI-compatible shim for decentralized Ollama inference.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "t4t": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ethersphere/bee-js": "^11.0.0",
    "express": "^4.21.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
